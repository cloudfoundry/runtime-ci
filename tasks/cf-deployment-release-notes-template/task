#!/bin/bash
set -exu

SCRIPT_DIR=runtime-ci/tasks/cf-deployment-release-notes-template

pushd $SCRIPT_DIR
  PARSED_BUNDLE_VERSION=$(sed -n '/BUNDLED WITH/{;n;p;}' Gemfile.lock | xargs)

  # Ruby images ship bundler as a default gem; only install the locked version if missing.
  if ! gem list -i bundler -v "$PARSED_BUNDLE_VERSION"; then
    gem install bundler --version "$PARSED_BUNDLE_VERSION"
  fi

  bundle install --without development
popd

BUNDLE_GEMFILE=$SCRIPT_DIR/Gemfile \
  bundle exec ruby $SCRIPT_DIR/task.rb
